{
  "name": "@kyc-rip/ripley-guard-ts",
  "repository": {
    "url": "https://github.com/KYC-rip/ripley-guard-ts.git"
  },
  "publisher": "KYC.rip",
  "version": "1.0.0",
  "description": "Stateless XMR402 protocol middleware for Hono and Express. Tactical Monero payment gating.",
  "keywords": [
    "monero",
    "xmr",
    "xmr402",
    "http-402",
    "ai-agents",
    "m2m-payments",
    "crypto-gateway",
    "hono",
    "express"
  ],
  "type": "module",
  "exports": {
    "./express": {
      "import": "./dist/express.js",
      "require": "./dist/express.cjs",
      "types": "./dist/express.d.ts"
    },
    "./hono": {
      "import": "./dist/hono.js",
      "require": "./dist/hono.cjs",
      "types": "./dist/hono.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "author": "XBToshi",
  "license": "MIT",
  "peerDependencies": {
    "express": "^4.18.0",
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}