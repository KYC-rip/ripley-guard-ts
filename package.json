{
  "name": "@kyc-rip/ripley-guard-ts",
  "repository": {
    "url": "https://github.com/KYC-rip/ripley-guard-ts.git"
  },
  "publisher": "KYC.rip",
  "version": "2.0.0",
  "description": "Stateless XMR402 Protocol v2.0. Transport-Agnostic Monero Payment Gating (HTTP/WS/Nostr).",
  "keywords": [
    "monero",
    "xmr",
    "xmr402",
    "http-402",
    "ai-agents",
    "m2m-payments",
    "crypto-gateway",
    "hono",
    "express",
    "websocket",
    "nostr",
    "relay",
    "x402",
    "middleware"
  ],
  "type": "module",
  "exports": {
    "./express": {
      "import": "./dist/http/express.js",
      "require": "./dist/http/express.cjs",
      "types": "./dist/http/express.d.ts"
    },
    "./hono": {
      "import": "./dist/http/hono.js",
      "require": "./dist/http/hono.cjs",
      "types": "./dist/http/hono.d.ts"
    },
    "./ws": {
      "import": "./dist/ws/relay.js",
      "require": "./dist/ws/relay.cjs",
      "types": "./dist/ws/relay.d.ts"
    },
    "./ws/adapter": {
      "import": "./dist/ws/adapter.js",
      "require": "./dist/ws/adapter.cjs",
      "types": "./dist/ws/adapter.d.ts"
    },
    "./nostr": {
      "import": "./dist/ws/nostr.js",
      "require": "./dist/ws/nostr.cjs",
      "types": "./dist/ws/nostr.d.ts"
    },
    "./core": {
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "types": "./dist/core.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "author": "XBToshi",
  "license": "MIT",
  "peerDependencies": {
    "express": "^4.18.0",
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3"
  }
}